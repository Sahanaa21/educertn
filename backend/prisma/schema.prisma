// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  COMPANY
}

enum CertificateStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum VerificationStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AcademicServiceType {
  PHOTOCOPY
  REEVALUATION
}

enum AcademicServiceStatus {
  PENDING
  UNDER_REVIEW
  RESULT_PUBLISHED
  REJECTED
}

enum CopyType {
  SOFT_COPY
  HARD_COPY
  BOTH
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certificateRequests CertificateRequest[]
  academicServiceRequests AcademicServiceRequest[]
  studentProfile      StudentProfile?
  companyProfile      CompanyProfile?
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CertificateRequest {
  id                   String            @id @default(uuid())
  userId               String
  user                 User              @relation(fields: [userId], references: [id])
  usn                  String
  studentName          String
  branch               String
  yearOfPassing        String
  phoneNumber          String?
  certificateType      String
  copyType             CopyType
  copies               Int
  reason               String?
  address              String?
  idProofUrl           String?
  supportingDocsUrl    String?
  paymentStatus        String            @default("PENDING") // PENDING, PAID, FAILED
  amount               Float             @default(0)
  paymentOrderId       String?
  status               CertificateStatus @default(PENDING)
  rejectionReason      String?
  physicalCopyPosted   Boolean           @default(false)
  softCopyEmailed      Boolean           @default(false)
  issuedCertificateUrl String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model VerificationRequest {
  id               String             @id @default(uuid())
  requestId        String             @unique
  companyName      String
  companyEmail     String
  contactPerson    String
  phone            String?
  studentName      String
  usn              String
  uploadedTemplate String
  completedFile    String?
  paymentOrderId   String?
  paymentStatus    String             @default("PENDING")
  status           VerificationStatus @default(PENDING)
  rejectionReason  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model IssueReport {
  id             String      @id @default(uuid())
  title          String
  description    String
  category       String
  pageUrl        String?
  reportedByName String?
  reportedByEmail String?
  role           String?
  deviceInfo     String?
  status         IssueStatus @default(OPEN)
  adminNotes     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model PortalSettings {
  id                 Int      @id
  supportEmail       String
  frontendUrl        String
  maintenanceMode    Boolean  @default(false)
  allowCompanySignup Boolean  @default(true)
  smtpFromName       String
  adminAllowedEmails String   @default("")
  academicServicesEnabled Boolean @default(false)
  academicServicesStartAt DateTime?
  academicServicesEndAt DateTime?
  updatedAt          DateTime @updatedAt
}

model AcademicServiceRequest {
  id               String                @id @default(uuid())
  requestId        String                @unique
  userId           String
  user             User                  @relation(fields: [userId], references: [id])
  serviceType      AcademicServiceType
  semester         String
  courseCount      Int
  courseNames      Json
  amount           Float
  paymentStatus    String                @default("PENDING")
  paymentOrderId   String?
  status           AcademicServiceStatus @default(PENDING)
  adminRemarks     String?
  resultSummary    String?
  attachmentUrls   Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model StudentProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usn           String
  branch        String
  yearOfPassing String
  phoneNumber   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanyProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  contactPerson String
  phoneNumber   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
