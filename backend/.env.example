# Backend environment template (SAFE TO COMMIT)
# Copy this file to .env and replace the values for your environment.
#
# College handover rule:
# - Keep the keys.
# - Replace the values with the college server, SMTP, and payment credentials.
# - Leave a value blank only if the feature is intentionally disabled.

# Runtime
NODE_ENV=development
PORT=5000

# Database
# College server setup: replace these with the college PostgreSQL host, port, user, password, and database.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=educert
# Either DATABASE_URL or the DB_* values can be used. Keep both in sync.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/educert?schema=public

# App URLs
# Update these when the frontend/back-end move to the college domain.
BASE_URL=http://localhost:5000
BACKEND_PUBLIC_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000

# Auth and admin bootstrap
JWT_SECRET=replace-with-long-random-secret
ISSUE_MAIL_ACTION_SECRET=replace-with-long-random-secret
ADMIN_BOOTSTRAP_EMAILS=admin@example.com,sahanaa2060@gmail.com
ADMIN_ALERT_EMAIL=admin@example.com
CRITICAL_ISSUE_EMAILS=

# Observability
SENTRY_DSN=
SENTRY_TRACE_SAMPLE_RATE=0.05

# Performance monitoring
SLOW_REQUEST_THRESHOLD_MS=1000
CRITICAL_REQUEST_THRESHOLD_MS=5000

# SMTP / Email provider
# For testing you can keep a personal SMTP account here.
# For college deployment, replace with the institution SMTP or approved relay.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace
SMTP_PASS=replace
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Global Academy of Technology
SMTP_FORCE_IPV4=true
SMTP_SECURE=false

# Payment provider (Zwitch)
# Use sandbox values for testing. Replace with live values at handover if payments are enabled.
ZWITCH_API_BASE_URL=https://api.zwitch.io
ZWITCH_CREATE_ORDER_PATH=/v1/pg/sandbox/payment_token
ZWITCH_FETCH_ORDER_PATH_TEMPLATE=/v1/pg/sandbox/payment_token/{orderId}/payment
ZWITCH_API_KEY=replace
ZWITCH_API_SECRET=replace
ZWITCH_AUTH_HEADER=
ZWITCH_LAYER_ACCESS_KEY=replace
ZWITCH_ACCESS_KEY=
ZWITCH_CHECKOUT_KEY_PREFERENCE=pg
ZWITCH_CHECKOUT_ENV=sandbox
ZWITCH_API_TIMEOUT_MS=6000
ZWITCH_DEFAULT_CONTACT=9999999999
ZWITCH_DEFAULT_EMAIL=noreply@example.com
