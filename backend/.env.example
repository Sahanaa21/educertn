# Backend environment template (safe to commit)
# Copy to backend/.env.
# Demo-first rule: test with safe/demo values, then replace only values for go-live.

# Runtime
NODE_ENV=production
PORT=5000

# Database (required)
# Option A: set DATABASE_URL directly.
# Option B: fill DB_* and leave DATABASE_URL blank.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=educert
DATABASE_URL=mysql://root:password@localhost:3306/educert

# URLs (required)
BASE_URL=http://127.0.0.1:5000
BACKEND_PUBLIC_URL=http://localhost:5000
BACKEND_URL=http://127.0.0.1:5000
FRONTEND_URL=http://127.0.0.1:3000
FRONTEND_URLS=http://127.0.0.1:3000

# Auth and admin bootstrap (required)
JWT_SECRET=your_secret_key
ISSUE_MAIL_ACTION_SECRET=replace_with_another_long_random_secret
ADMIN_BOOTSTRAP_EMAILS=admin@college.edu
CRITICAL_ISSUE_EMAILS=admin@college.edu,itsupport@college.edu

# Error reporting (optional - leave blank to keep everything local)
SENTRY_DSN=
SENTRY_TRACE_SAMPLE_RATE=0.05

# Performance thresholds
SLOW_REQUEST_THRESHOLD_MS=1000
CRITICAL_REQUEST_THRESHOLD_MS=5000

# SMTP mailer (optional for local testing; keep internal/local relay for offline usage)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@college.edu
SMTP_FROM_NAME=College Verification Portal
SMTP_FORCE_IPV4=true
SMTP_SECURE=false

# Payment gateway (optional; keep empty for local/offline environment)
ZWITCH_API_BASE_URL=
ZWITCH_CREATE_ORDER_PATH=/v1/pg/sandbox/payment_token
ZWITCH_FETCH_ORDER_PATH_TEMPLATE=/v1/pg/sandbox/payment_token/{orderId}/payment
ZWITCH_API_KEY=
ZWITCH_API_SECRET=
ZWITCH_AUTH_HEADER=
ZWITCH_LAYER_ACCESS_KEY=
ZWITCH_ACCESS_KEY=
ZWITCH_CHECKOUT_KEY_PREFERENCE=pg
ZWITCH_CHECKOUT_ENV=
ZWITCH_API_TIMEOUT_MS=6000
ZWITCH_DEFAULT_CONTACT=9999999999
ZWITCH_DEFAULT_EMAIL=noreply@college.edu

# Optional script-only health check overrides
HEALTH_BASE_URL=http://127.0.0.1:5000
HEALTH_TIMEOUT_MS=6000
