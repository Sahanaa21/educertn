# Backend environment template (SAFE TO COMMIT)
# Copy this file to .env and fill values for your current environment.

# Runtime
NODE_ENV=development
PORT=5000

# Observability & Error Tracking
SENTRY_DSN=
SENTRY_TRACE_SAMPLE_RATE=0.05

# Performance Monitoring
# Milliseconds threshold for logging slow requests
SLOW_REQUEST_THRESHOLD_MS=1000
CRITICAL_REQUEST_THRESHOLD_MS=5000

# Core app
# Connection string with pool parameters:
# ?schema=public&connection_limit=20&pool_timeout=30&max_overflow=5
# - connection_limit: max connections in pool (default 10, higher for production)
# - pool_timeout: seconds to wait for a connection (default 30)
# - max_overflow: max connections beyond connection_limit (default 2)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public&connection_limit=15
JWT_SECRET=replace-with-long-random-secret
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,https://your-staging-frontend.example.com
BACKEND_PUBLIC_URL=http://localhost:5000
ADMIN_ALERT_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
CRITICAL_ISSUE_EMAILS=
ISSUE_MAIL_ACTION_SECRET=replace-with-long-random-secret
SENTRY_DSN=

# SMTP / Email provider (current SMTP now, college can switch to SES or institutional SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace
SMTP_PASS=replace
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Global Academy of Technology
SMTP_FORCE_IPV4=true
SMTP_SECURE=false

# Payment provider (Zwitch sandbox -> live key swap at handover)
ZWITCH_API_BASE_URL=https://api.zwitch.io
ZWITCH_CREATE_ORDER_PATH=/v1/pg/sandbox/payment_token
ZWITCH_FETCH_ORDER_PATH_TEMPLATE=/v1/pg/sandbox/payment_token/{orderId}/payment
ZWITCH_API_KEY=replace
ZWITCH_API_SECRET=replace
ZWITCH_AUTH_HEADER=
ZWITCH_LAYER_ACCESS_KEY=replace
ZWITCH_ACCESS_KEY=
ZWITCH_CHECKOUT_KEY_PREFERENCE=pg
ZWITCH_CHECKOUT_ENV=sandbox
ZWITCH_API_TIMEOUT_MS=6000
ZWITCH_DEFAULT_CONTACT=9999999999
ZWITCH_DEFAULT_EMAIL=noreply@example.com

# AWS S3 uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
